{
    "name": "chatbot-app-server",
    "version": "1.0.0",
    "description": "Server for ChatbotApp",
    "main": "dist/server.js",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "nodemon server.ts",
        "build": "tsc",
        "test": "jest --runInBand"
    },
    "keywords": [
        "chatbot",
        "openai",
        "express"
    ],
    "author": "",
    "license": "ISC",
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testMatch": [
            "**/__tests__/**/*.test.ts"
        ]
    },
    "dependencies": {
        "bcrypt": "^5.1.0",
        "cors": "^2.8.5",
        "crypto-js": "^4.1.1",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.0",
        "mongoose": "^7.2.2",
        "openai": "^6.45.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.0",
        "@types/cors": "^2.8.13",
        "@types/crypto-js": "^4.1.1",
        "@types/express": "^4.17.17",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.2",
        "@types/node": "^20.17.6",
        "@types/supertest": "^7.2.0",
        "autoprefixer": "^10.4.20",
        "jest": "^30.4.2",
        "mongodb-memory-server": "^11.2.0",
        "nodemon": "^2.0.22",
        "postcss": "^8.4.49",
        "supertest": "^7.2.2",
        "tailwindcss": "^3.4.15",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.1",
        "typescript": "^5.0.4"
    }
}
